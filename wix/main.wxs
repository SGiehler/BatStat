<?xml version='1.0' encoding='windows-1252'?>
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
    <Product
        Id='*'
        Name='BatStat'
        UpgradeCode='6E136005-402D-EFB1-B596-FA0EE31FF30C'
        Manufacturer='SGiehler'
        Language='1033'
        Codepage='1252'
        Version='1.0.0'>

        <Package
            Id='*'
            Keywords='Installer'
            Description='A lightweight Windows battery monitor for peripherals'
            Manufacturer='SGiehler'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            SummaryCodepage='1252'
        />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'
        />

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1' />
        <Property Id='DiskPrompt' Value='BatStat Installation [1]' />

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFilesFolder' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='BatStat'>
                    <Component Id='License' Guid='*'>
                        <File Id='LicenseFile' Name='LICENSE' Source='LICENSE' KeyPath='yes'/>
                    </Component>

                    <Component Id='Executable' Guid='*'>
                        <File Id='ExecutableFile' Name='batstat.exe' Source='target\release\batstat.exe' KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
            
            <Directory Id='DesktopFolder' Name='Desktop'/>
        </Directory>

        <DirectoryRef Id='DesktopFolder'>
            <Component Id='DesktopShortcutComponent' Guid='D48A62BD-ED9D-70D6-A2FF-99DEB6ACFECC'>
                <Shortcut
                    Id='DesktopShortcut'
                    Name='BatStat'
                    Description='BatStat Battery Monitor'
                    Target='[APPLICATIONFOLDER]batstat.exe'
                    WorkingDirectory='APPLICATIONFOLDER'
                />
                <RegistryValue
                    Root='HKCU'
                    Key='Software\SGiehler\BatStat'
                    Name='desktop_shortcut'
                    Type='integer'
                    Value='1'
                    KeyPath='yes'
                />
            </Component>
        </DirectoryRef>

        <Feature Id='Main' Title='Installation' Level='1'>
            <ComponentRef Id='License'/>
            <ComponentRef Id='Executable'/>
            <ComponentRef Id='DesktopShortcutComponent'/>
        </Feature>
    </Product>
</Wix>
